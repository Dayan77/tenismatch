# ── Banco de dados ────────────────────────────────────────────
# Conexão PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/tennismatch

# ── Anthropic (Claude) ────────────────────────────────────────
# Chave da API Anthropic para o agente de IA
ANTHROPIC_API_KEY=sk-ant-...

# ── Evolution API (WhatsApp) ──────────────────────────────────
# URL base do servidor Evolution API no VPS (sem barra final)
# Exemplo: http://187.77.144.79:8080
EVOLUTION_API_URL=http://SEU_VPS:8080
# API key global definida no painel/variável de ambiente da Evolution API
EVOLUTION_API_KEY=SUA_API_KEY
# Nome da instância criada na Evolution API (painel → Instâncias → criar)
EVOLUTION_INSTANCE=nome-da-instancia

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
# Fuso horário para exibição de datas
TZ=America/Sao_Paulo

# ── Webhook ───────────────────────────────────────────────────
# Configure no painel da Evolution API → Instância → Webhooks:
#   URL:    http://seu-dominio.com/webhook/whatsapp
#   Evento: messages.upsert
# A Evolution API autentica o webhook enviando o header "apikey" com EVOLUTION_API_KEY
PUBLIC_URL=https://seu-dominio.com
